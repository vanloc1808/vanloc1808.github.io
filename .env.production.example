# EmailJS Configuration (for contact form)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Google Analytics/Tag Manager (optional)
NEXT_PUBLIC_GTM=your_google_tag_manager_id

# Application URL (change this to your domain)
NEXT_PUBLIC_APP_URL=https://nguyenvanloc.com

# reCAPTCHA Configuration (for contact form protection)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Telegram Bot Configuration (for contact notifications - optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id