{
  "entryPoints": ["./app", "./types", "./utils"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "theme": "default",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "gitRevision": "main",
  "sort": ["source-order"],
  "plugin": ["typedoc-plugin-markdown"],
  "hideGenerator": false,
  "searchInComments": true,
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Components",
    "Pages",
    "Types",
    "Utils",
    "Context",
    "Hooks",
    "*"
  ],
  "emit": "both"
}
